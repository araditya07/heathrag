# Supabase — create a project at supabase.com, then go to Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini — get a key at https://aistudio.google.com (no credit card)
GEMINI_API_KEY=

# Optional: Ollama for offline LLM fallback. Install via `brew install ollama` and
# pull a model with `ollama pull llama3.1:8b`. Leave default URL if running locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Model overrides (optional)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
GEMINI_MODEL=gemini-2.5-flash
