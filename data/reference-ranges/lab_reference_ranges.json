    "unit": "ng/mL",
    "aliases": ["serum ferritin"],
    "ranges": {
      "adult_male": {"low": 30, "high": 400},
      "adult_female": {"low": 15, "high": 200},
      "default": {"low": 15, "high": 400}
    },
    "what_it_measures": "Iron storage protein. Low = iron-deficiency anemia."
  },
  "iron": {
    "unit": "µg/dL",
    "aliases": ["serum iron"],
    "ranges": {
      "default": {"low": 60, "high": 170}
    },
    "what_it_measures": "Circulating iron levels."
  },
