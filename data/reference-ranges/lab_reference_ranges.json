    "unit": "mg/dL",
    "aliases": ["urate", "serum uric acid"],
    "ranges": {
      "adult_male": {"low": 3.4, "high": 7.0},
      "adult_female": {"low": 2.4, "high": 6.0},
      "default": {"low": 2.4, "high": 7.0}
    },
