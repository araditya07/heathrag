{
  "hemoglobin": {
    "unit": "g/dL",
    "aliases": ["haemoglobin", "hb", "hgb"],
    "ranges": {
      "adult_male": {"low": 13.0, "high": 17.5},
      "adult_female": {"low": 12.0, "high": 15.5},
      "child": {"low": 11.0, "high": 16.0},
      "default": {"low": 12.0, "high": 17.5}
    },
    "what_it_measures": "Oxygen-carrying protein in red blood cells. Low values suggest anemia."
  },
  "hba1c": {
    "unit": "%",
    "aliases": ["glycated hemoglobin", "glycated haemoglobin", "a1c", "hba1c"],
    "ranges": {
      "normal": {"low": 0, "high": 5.6},
      "prediabetic": {"low": 5.7, "high": 6.4},
      "diabetic": {"low": 6.5, "high": 100},
      "default": {"low": 0, "high": 5.6}
    },
    "what_it_measures": "Average blood sugar over the past 2-3 months. Used to diagnose and monitor diabetes."
  },
  "total_cholesterol": {
    "unit": "mg/dL",
    "aliases": ["total cholesterol", "cholesterol total", "t. cholesterol", "tc"],
    "ranges": {
      "default": {"low": 0, "high": 200}
    },
    "what_it_measures": "Sum of LDL, HDL, and other lipid components. High values increase cardiovascular risk."
  },
  "ldl": {
    "unit": "mg/dL",
    "aliases": ["low density lipoprotein", "ldl-c", "ldl cholesterol"],
    "ranges": {
      "default": {"low": 0, "high": 100}
    },
    "what_it_measures": "\"Bad\" cholesterol. High levels build up plaque in arteries."
  },
  "hdl": {
    "unit": "mg/dL",
    "aliases": ["high density lipoprotein", "hdl-c", "hdl cholesterol"],
    "ranges": {
      "adult_male": {"low": 40, "high": 1000},
      "adult_female": {"low": 50, "high": 1000},
      "default": {"low": 40, "high": 1000}
    },
    "what_it_measures": "\"Good\" cholesterol. Higher is better — it helps remove other cholesterol from the bloodstream."
  },
  "triglycerides": {
    "unit": "mg/dL",
    "aliases": ["triglyceride", "tg"],
    "ranges": {
      "default": {"low": 0, "high": 150}
    },
    "what_it_measures": "A type of fat in the blood. High values increase risk of pancreatitis and heart disease."
  },
  "creatinine": {
    "unit": "mg/dL",
    "aliases": ["serum creatinine", "s. creatinine", "creat", "s. creat"],
    "ranges": {
      "adult_male": {"low": 0.7, "high": 1.3},
      "adult_female": {"low": 0.6, "high": 1.1},
      "default": {"low": 0.6, "high": 1.3}
    },
    "what_it_measures": "Waste product filtered by the kidneys. High values may indicate impaired kidney function."
  },
  "blood_urea_nitrogen": {
    "unit": "mg/dL",
    "aliases": ["bun", "urea nitrogen", "blood urea"],
    "ranges": {
      "default": {"low": 7, "high": 20}
    },
    "what_it_measures": "Nitrogen from urea, filtered by kidneys. Reflects kidney function and protein metabolism."
  },
  "tsh": {
    "unit": "mIU/L",
    "aliases": ["thyroid stimulating hormone", "t.s.h.", "thyrotropin"],
    "ranges": {
      "default": {"low": 0.4, "high": 4.0}
    },
    "what_it_measures": "Pituitary hormone that regulates thyroid. High = hypothyroidism; low = hyperthyroidism."
  },
  "t3": {
    "unit": "ng/dL",
    "aliases": ["triiodothyronine", "free t3", "ft3"],
    "ranges": {
      "default": {"low": 80, "high": 200}
    },
    "what_it_measures": "Active thyroid hormone."
  },
  "t4": {
    "unit": "µg/dL",
    "aliases": ["thyroxine", "free t4", "ft4"],
    "ranges": {
      "default": {"low": 4.5, "high": 12.0}
    },
    "what_it_measures": "Thyroid hormone, converted to T3 in tissues."
  },
  "fasting_glucose": {
    "unit": "mg/dL",
    "aliases": ["fasting blood sugar", "fbs", "glucose fasting", "fasting glucose"],
    "ranges": {
      "normal": {"low": 70, "high": 99},
      "prediabetic": {"low": 100, "high": 125},
      "diabetic": {"low": 126, "high": 1000},
      "default": {"low": 70, "high": 99}
    },
    "what_it_measures": "Blood sugar after at least 8 hours of fasting."
  },
  "random_glucose": {
    "unit": "mg/dL",
    "aliases": ["random blood sugar", "rbs", "glucose random"],
    "ranges": {
      "default": {"low": 70, "high": 140}
    },
