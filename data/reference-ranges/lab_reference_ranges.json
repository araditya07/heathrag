  },
  "potassium": {
    "unit": "mEq/L",
    "aliases": ["k", "k+", "serum potassium"],
    "ranges": {
      "default": {"low": 3.5, "high": 5.0}
    },
    "what_it_measures": "Electrolyte critical for heart and muscle function."
  },
  "sodium": {
    "unit": "mEq/L",
    "aliases": ["na", "na+", "serum sodium"],
    "ranges": {
      "default": {"low": 135, "high": 145}
    },
    "what_it_measures": "Main electrolyte in blood. Regulates fluid balance."
  },
  "platelets": {
    "unit": "/µL",
    "aliases": ["platelet count", "plt"],
    "ranges": {
      "default": {"low": 150000, "high": 450000}
    },
    "what_it_measures": "Cells that help blood clot. Low = bleeding risk; high = clotting risk."
  },
  "wbc": {
    "unit": "/µL",
    "aliases": ["white blood cell count", "wbc count", "leukocytes"],
    "ranges": {
      "default": {"low": 4000, "high": 11000}
    },
    "what_it_measures": "Immune cells. High = infection or inflammation; low = immunosuppression."
  },
  "rbc": {
    "unit": "million/µL",
    "aliases": ["red blood cell count", "rbc count", "erythrocytes"],
    "ranges": {
      "adult_male": {"low": 4.7, "high": 6.1},
      "adult_female": {"low": 4.2, "high": 5.4},
      "default": {"low": 4.2, "high": 6.1}
    },
    "what_it_measures": "Oxygen-carrying cells."
  },
  "vitamin_d": {
    "unit": "ng/mL",
    "aliases": ["25-oh vitamin d", "25-hydroxyvitamin d", "vit d", "vitamin d 25"],
    "ranges": {
      "default": {"low": 30, "high": 100}
    },
    "what_it_measures": "Vitamin D status. <20 = deficient; 20-29 = insufficient; 30+ = adequate."
  },
  "vitamin_b12": {
    "unit": "pg/mL",
    "aliases": ["b12", "cobalamin", "vit b12"],
    "ranges": {
      "default": {"low": 200, "high": 900}
    },
    "what_it_measures": "Vitamin B12 status. Low values can cause anemia and neurological issues."
