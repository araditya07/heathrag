    "unit": "U/L",
    "aliases": ["alp", "alk phos"],
    "ranges": {
      "default": {"low": 44, "high": 147}
    },
    "what_it_measures": "Enzyme involved in liver and bone."
  },
  "bilirubin_total": {
    "unit": "mg/dL",
    "aliases": ["total bilirubin", "t. bilirubin", "tbil"],
    "ranges": {
      "default": {"low": 0.1, "high": 1.2}
    },
    "what_it_measures": "Breakdown product of red blood cells. High = jaundice or liver issue."
  },
