    "unit": "mg/dL",
    "aliases": ["serum calcium", "ca", "ca++"],
    "ranges": {
      "default": {"low": 8.5, "high": 10.5}
    },
    "what_it_measures": "Mineral critical for bone, muscle, and nerve function."
  },
