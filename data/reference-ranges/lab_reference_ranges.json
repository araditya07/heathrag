    "unit": "mm/hr",
    "aliases": ["erythrocyte sedimentation rate"],
    "ranges": {
      "adult_male": {"low": 0, "high": 22},
      "adult_female": {"low": 0, "high": 29},
      "default": {"low": 0, "high": 29}
    },
    "what_it_measures": "Nonspecific marker of inflammation."
  },
  "crp": {
    "unit": "mg/L",
    "aliases": ["c-reactive protein", "c reactive protein"],
